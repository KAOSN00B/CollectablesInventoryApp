generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Collection {
  id          Int      @id @default(autoincrement())
  publicCode  String   @unique
  displayName String?
  createdAt   DateTime @default(now())

  items    CollectionItem[]
  wishlist WishlistItem[]

  @@map("collections")
}

model CatalogItem {
  id             Int     @id @default(autoincrement())
  type           String  // "GAME" or "CONSOLE"
  title          String
  platform       String
  upc            String?
  looseValue     Float   @default(0)
  cibValue       Float   @default(0)
  newValue       Float   @default(0)
  genre          String?
  releaseYear    Int?
  imageUrl       String?
  searchableText String  // title + platform + genre for pg_trgm fuzzy search

  items         CollectionItem[]
  wishlistItems WishlistItem[]

  @@unique([title, platform])
  @@map("catalog_items")
}

model CollectionItem {
  id             Int      @id @default(autoincrement())
  collectionId   Int
  catalogItemId  Int?
  type           String   // "GAME", "CONSOLE", "TCG", "COLLECTIBLE"
  title          String
  platform       String   // for TCG this stores the set name
  condition      String   // LOOSE/CIB/NEW/POOR for games; NM/LP/MP/HP/DMG for TCG
  purchasePrice  Float    @default(0)
  estimatedValue Float    @default(0)
  notes          String?
  forTrade       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // TCG-specific fields — null for all game/console rows
  tcgGame       String?  // "MTG" | "POKEMON" | "YUGIOH"
  tcgSet        String?  // "Scarlet & Violet Base Set"
  tcgSetCode    String?  // "SVP" — used to re-fetch prices from the API later
  tcgCardNumber String?  // "001/250"
  tcgRarity     String?  // "Rare Holo", "Mythic Rare", "Common"
  tcgIsFoil     Boolean? // foil/holo variant — worth significantly more than non-foil
  tcgExternalId String?  // Scryfall UUID, PokémonTCG card ID, or YGOPro card ID
  quantity      Int?     // how many copies owned (players often have 4x of a card)

  collection  Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id])

  @@map("collection_items")
}

model WishlistItem {
  id                    Int     @id @default(autoincrement())
  collectionId          Int
  catalogItemId         Int?
  title                 String
  platform              String
  targetPrice           Float   @default(0)
  currentEstimatedValue Float   @default(0)
  notes                 String?
  isGrail               Boolean @default(false)

  collection  Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id])

  @@map("wishlist_items")
}

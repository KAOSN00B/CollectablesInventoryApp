<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vault_background">

    <!-- Shown while dashboard data is loading -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/vault_surface_high"
            app:strokeColor="@color/vault_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Collection Value"
                    android:textColor="@color/vault_text_muted"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <TextView
                    android:id="@+id/grand_total_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="$0.00"
                    android:textColor="@color/vault_secondary"
                    android:textAppearance="?attr/textAppearanceDisplaySmall" />

                <TextView
                    android:id="@+id/total_item_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0 items in collection"
                    android:textColor="@color/vault_text_muted"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_scan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_add"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Add" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_binders"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="View Binders" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="By Category"
            android:textColor="@color/vault_text"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="8dp" />

        <!-- Video Games card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/vault_surface"
            app:strokeColor="@color/vault_outline"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Video Games"
                        android:textColor="@color/vault_text" android:textAppearance="?attr/textAppearanceTitleSmall" />
                    <TextView android:id="@+id/games_category_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/vault_secondary"
                        android:textStyle="bold" android:textAppearance="?attr/textAppearanceTitleSmall" />
                </LinearLayout>
                <TextView android:id="@+id/games_category_count" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="2dp"
                    android:textColor="@color/vault_text_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Trading Cards card with per-game breakdown -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tcg_card_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/vault_surface"
            app:strokeColor="@color/vault_outline"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Trading Cards"
                        android:textColor="@color/vault_text" android:textAppearance="?attr/textAppearanceTitleSmall" />
                    <TextView android:id="@+id/tcg_category_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/vault_secondary"
                        android:textStyle="bold" android:textAppearance="?attr/textAppearanceTitleSmall" />
                </LinearLayout>
                <TextView android:id="@+id/tcg_category_count" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="2dp"
                    android:textColor="@color/vault_text_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
                <!-- Per-game breakdown rows -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginTop="10dp" android:layout_marginBottom="8dp"
                    android:background="@color/vault_outline" />
                <LinearLayout android:id="@+id/tcg_mtg_row" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:layout_marginBottom="4dp" android:visibility="gone">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="  ↳ MTG"
                        android:textColor="@color/vault_text_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
                    <TextView android:id="@+id/tcg_mtg_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/vault_text_muted"
                        android:textAppearance="?attr/textAppearanceBodySmall" />
                </LinearLayout>
                <LinearLayout android:id="@+id/tcg_pokemon_row" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:layout_marginBottom="4dp" android:visibility="gone">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="  ↳ Pokémon"
                        android:textColor="@color/vault_text_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
                    <TextView android:id="@+id/tcg_pokemon_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/vault_text_muted"
                        android:textAppearance="?attr/textAppearanceBodySmall" />
                </LinearLayout>
                <LinearLayout android:id="@+id/tcg_yugioh_row" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:visibility="gone">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="  ↳ Yu-Gi-Oh!"
                        android:textColor="@color/vault_text_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
                    <TextView android:id="@+id/tcg_yugioh_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/vault_text_muted"
                        android:textAppearance="?attr/textAppearanceBodySmall" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Collectibles card (hidden until items added) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/collectibles_card_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/vault_surface"
            app:strokeColor="@color/vault_outline"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Collectibles"
                        android:textColor="@color/vault_text" android:textAppearance="?attr/textAppearanceTitleSmall" />
                    <TextView android:id="@+id/collectibles_category_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/vault_secondary"
                        android:textStyle="bold" android:textAppearance="?attr/textAppearanceTitleSmall" />
                </LinearLayout>
                <TextView android:id="@+id/collectibles_category_count" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="2dp"
                    android:textColor="@color/vault_text_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hidden legacy IDs kept for reference, not shown -->
        <TextView android:id="@+id/consoles_category_value" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/consoles_category_count" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/comics_category_value" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/comics_category_count" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/toys_category_value" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/toys_category_count" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/lego_category_value" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/lego_category_count" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        <TextView
            android:id="@+id/wishlist_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/vault_secondary"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginBottom="16dp" />

        <!-- Top 5 most valuable items -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Top 5 Most Valuable"
            android:textColor="@color/vault_text"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/vault_surface"
            app:strokeColor="@color/vault_outline"
            app:strokeWidth="1dp">
            <TextView
                android:id="@+id/top_valuable_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textColor="@color/vault_text_muted"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:lineSpacingMultiplier="1.5" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recently Added"
            android:textColor="@color/vault_text"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/recent_games_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/vault_text_muted"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="16dp" />

        <!-- Share collection link -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/share_collection_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Share My Collection" />

    </LinearLayout>
    </ScrollView>

</FrameLayout>

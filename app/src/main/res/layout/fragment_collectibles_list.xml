<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Chip filter row for category selection -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_comics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comics"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_tcg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TCG"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_toys"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toys"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_lego"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEGO"
                style="@style/Widget.Material3.Chip.Filter" />

        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/empty_state_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No collectibles yet — tap + to add one"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:gravity="center"
        android:layout_margin="32dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/collectibles_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_collectible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Add collectible"
        android:src="@android:drawable/ic_input_add" />

</LinearLayout>
